{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "UI Concepts Static Server",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "py -3 -m http.server 8090 --directory ."],
      "port": 8090
    },
    {
      "name": "Expo Dev Server (QR / Expo Go)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "npm run start"],
      "port": 8081
    },
    {
      "name": "Expo Web (browser)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "set BROWSER=chrome && npx expo start --web --clear"],
      "port": 8081
    },
    {
      "name": "Expo Android",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "npm run android"],
      "port": 8081
    },
    {
      "name": "Expo iOS",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "npm run ios"],
      "port": 8081
    }
  ]
}
